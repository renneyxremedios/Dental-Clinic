---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import DoctorCard from "../components/DoctorCard.astro";
import { doctors } from "../data/site";
---

<BaseLayout
  title="Our Doctors"
  description="Meet our team of expert dentists at Bright Smile Dental — general, orthodontic, pediatric, and surgical specialists dedicated to your care."
>
  <Hero
    eyebrow="Our Team"
    title="Highly trained, compassionate professionals."
    subtitle="Every member of our team is dedicated to making your visit comfortable, informed, and effective."
  />

  <section class="section">
    <div class="container-page">
      <div class="grid gap-6 sm:grid-cols-2 max-w-4xl mx-auto">
        {doctors.map((d) => <DoctorCard doctor={d} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-primary-600 to-primary-800 p-10 md:p-14 text-center text-white shadow-lift">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight">Found the right doctor for you?</h2>
        <p class="mt-2 text-primary-100">Book online and we'll match you with your preferred provider.</p>
        <a href="/appointment" class="inline-flex mt-6 bg-white text-primary-700 hover:bg-primary-50 btn">
          Book Appointment →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
