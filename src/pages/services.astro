---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { services } from "../data/site";
---

<BaseLayout
  title="Dental Services"
  description="Explore our full range of dental services — cleanings, implants, whitening, braces, veneers, crowns, root canals, and emergency care."
>
  <Hero
    eyebrow="Our Services"
    title="Comprehensive dental care under one roof."
    subtitle="From routine checkups to full smile makeovers — explore our complete range of services."
    primaryCta={{ label: "Book Appointment", href: "/appointment" }}
  />

  <section class="section">
    <div class="container-page">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => <div id={s.slug}><ServiceCard service={s} /></div>)}
      </div>
    </div>
  </section>

  <!-- "Not sure" sub-CTA -->
  <section class="section bg-secondary-50">
    <div class="container-page text-center max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight">Not sure which service you need?</h2>
      <p class="mt-3 text-secondary-600">
        Book a free consultation and we'll assess your smile, answer your questions, and recommend the right treatment.
      </p>
      <a href="/appointment" class="btn btn-primary mt-6">Book a Consultation</a>
    </div>
  </section>
</BaseLayout>
