---
import BaseLayout from "../layouts/BaseLayout.astro";
import ClinicMap from "../components/islands/ClinicMap.tsx";
import ContactForm from "../components/islands/ContactForm.tsx";
import { site } from "../data/site";
import { icons } from "../lib/icons";
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${site.name}. Visit us at ${site.address.line1}, call ${site.phone}, or send us a message.`}
>
  <section class="bg-gradient-to-br from-primary-50 via-white to-secondary-50">
    <div class="container-page section">
      <div class="max-w-2xl">
        <span class="eyebrow">Contact</span>
        <h1 class="mt-2 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight">Get in touch</h1>
        <p class="mt-4 text-lg text-secondary-600">
          Visit our clinic, call us, or send a message. We're here to help.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page grid gap-6 lg:grid-cols-2">
      <!-- Address & Hours -->
      <div class="card p-6 md:p-8">
        <h2 class="text-xl font-semibold text-secondary-900">Visit us</h2>
        <div class="mt-5 space-y-4 text-secondary-700">
          <div class="flex items-start gap-3">
            <Fragment set:html={icons.mapPin({ class: "h-5 w-5 text-primary-600 mt-0.5 flex-shrink-0" })} />
            <div>
              <p class="font-medium text-secondary-900">{site.address.line1}</p>
              <p>{site.address.line2}</p>
            </div>
          </div>
          <a href={site.phoneHref} class="flex items-center gap-3 hover:text-primary-700">
            <Fragment set:html={icons.phone({ class: "h-5 w-5 text-primary-600 flex-shrink-0" })} />
            {site.phone}
          </a>
          <a href={site.emailHref} class="flex items-center gap-3 hover:text-primary-700">
            <Fragment set:html={icons.mail({ class: "h-5 w-5 text-primary-600 flex-shrink-0" })} />
            {site.email}
          </a>
        </div>

        <div class="mt-6 pt-6 border-t border-secondary-200">
          <h3 class="text-sm font-semibold uppercase tracking-widest text-secondary-500">Office hours</h3>
          <ul class="mt-3 space-y-2 text-sm">
            {site.hours.map((h) => (
              <li class="flex items-center gap-3">
                <Fragment set:html={icons.clock({ class: "h-4 w-4 text-primary-600" })} />
                <span class="text-secondary-700 w-24">{h.day}</span>
                <span class="font-medium text-secondary-900">{h.time}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Map -->
      <ClinicMap client:visible />
    </div>
  </section>

  <section class="section bg-secondary-50">
    <div class="container-page max-w-3xl">
      <div class="text-center mb-8">
        <span class="eyebrow">Message</span>
        <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">Send us a message</h2>
        <p class="mt-3 text-secondary-600">Have a question? We'll respond within one business day.</p>
      </div>
      <div class="card p-6 md:p-8">
        <ContactForm client:visible />
      </div>
    </div>
  </section>
</BaseLayout>
