---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppointmentForm from "../components/islands/AppointmentForm.tsx";
import { site } from "../data/site";
import { icons } from "../lib/icons";
---

<BaseLayout
  title="Book an Appointment"
  description={`Book your dental appointment online. We'll confirm your slot within 24 hours, or call us at ${site.phone}.`}
>
  <section class="bg-gradient-to-br from-primary-50 via-white to-secondary-50">
    <div class="container-page section">
      <div class="max-w-2xl">
        <span class="eyebrow">Book Online</span>
        <h1 class="mt-2 text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight">Book an appointment</h1>
        <p class="mt-4 text-lg text-secondary-600">
          Fill out the form below and we'll confirm your slot within 24 hours. Need it sooner? Give us a call.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page grid gap-10 lg:grid-cols-[1.4fr_1fr] items-start">
      <AppointmentForm client:load />

      <aside class="card p-6 md:p-8 bg-gradient-to-br from-primary-600 to-primary-800 text-white border-0">
        <h2 class="text-xl font-semibold">Prefer to call?</h2>
        <p class="mt-2 text-primary-100 text-sm">
          Our friendly front desk is happy to help you schedule, reschedule, or answer questions.
        </p>
        <a
          href={site.phoneHref}
          class="mt-5 inline-flex items-center gap-2 text-2xl font-bold text-white hover:text-primary-100"
        >
          <Fragment set:html={icons.phone({ class: "h-5 w-5" })} />
          {site.phone}
        </a>
        <div class="mt-6 pt-6 border-t border-white/20 text-sm text-primary-100">
          <p class="font-semibold text-white">Office hours</p>
          <ul class="mt-2 space-y-1">
            {site.hours.map((h) => (
              <li class="flex justify-between gap-4">
                <span>{h.day}</span>
                <span class="text-white">{h.time}</span>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
