---
import { site } from "../data/site";
import { icons } from "../lib/icons";

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const links: { href: string; label: string }[] = [
  { href: "/",            label: "Home" },
  { href: "/about",       label: "About" },
  { href: "/services",    label: "Services" },
  { href: "/doctors",     label: "Doctors" },
  { href: "/contact",     label: "Contact" },
];
---

<header class="sticky top-0 z-40 bg-white/85 backdrop-blur border-b border-secondary-200">
  <div class="container-page flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-primary-500 to-primary-700 text-white shadow-soft">
        <Fragment set:html={icons.sparkles({ class: "h-5 w-5" })} />
      </span>
      <span class="flex flex-col leading-tight">
        <span class="text-lg font-bold text-secondary-900 group-hover:text-primary-700 transition-colors">{site.shortName}</span>
        <span class="text-[10px] uppercase tracking-widest text-secondary-500">Dental</span>
      </span>
    </a>

    <!-- Pure-CSS hamburger toggle (no JS) -->
    <input type="checkbox" id="nav-toggle" class="peer hidden" aria-label="Toggle navigation" />
    <label
      for="nav-toggle"
      class="md:hidden inline-flex h-11 w-11 items-center justify-center rounded-lg text-secondary-700 hover:bg-primary-50 cursor-pointer"
    >
      <Fragment set:html={icons.menu({ class: "h-6 w-6 peer-checked:hidden" })} />
      <Fragment set:html={icons.x({ class: "h-6 w-6 hidden peer-checked:block" })} />
    </label>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "px-4 py-2 rounded-lg text-sm font-medium transition-colors",
            isActive(l.href)
              ? "text-primary-700 bg-primary-50"
              : "text-secondary-700 hover:text-primary-700 hover:bg-primary-50/60",
          ]}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Right-side CTA: visible on all sizes -->
    <a
      href="/appointment"
      class="btn btn-primary hidden md:inline-flex"
    >
      Book Appointment
      <Fragment set:html={icons.arrowRight({ class: "h-4 w-4" })} />
    </a>

    <!-- Mobile menu panel -->
    <div class="absolute top-full inset-x-0 md:hidden bg-white border-b border-secondary-200 shadow-soft hidden peer-checked:block">
      <nav class="container-page flex flex-col gap-1 py-4">
        {links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "px-4 py-3 rounded-lg text-base font-medium transition-colors",
              isActive(l.href)
                ? "text-primary-700 bg-primary-50"
                : "text-secondary-700 hover:text-primary-700 hover:bg-primary-50/60",
            ]}
          >
            {l.label}
          </a>
        ))}
        <a href="/appointment" class="btn btn-primary mt-2">
          Book Appointment
          <Fragment set:html={icons.arrowRight({ class: "h-4 w-4" })} />
        </a>
        <a
          href={site.phoneHref}
          class="btn btn-secondary mt-2"
        >
          <Fragment set:html={icons.phone({ class: "h-4 w-4" })} />
          {site.phone}
        </a>
      </nav>
    </div>
  </div>

  <!-- Sticky-bottom mobile CTA: always visible, full width -->
  <a
    href="/appointment"
    class="md:hidden fixed bottom-4 inset-x-4 z-30 btn btn-primary shadow-lift"
  >
    Book Appointment
    <Fragment set:html={icons.arrowRight({ class: "h-4 w-4" })} />
  </a>
</header>
