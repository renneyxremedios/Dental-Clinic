---
import { icons } from "../lib/icons";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  align = "left",
} = Astro.props;

const containerClass = align === "center"
  ? "text-center items-center"
  : "text-left items-start";
---

<section class="relative overflow-hidden">
  <!-- Decorative gradient background -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-primary-50 via-white to-secondary-50" aria-hidden="true"></div>
  <div class="absolute top-0 right-0 -z-10 w-[40rem] h-[40rem] rounded-full bg-primary-100/40 blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 -z-10 w-[30rem] h-[30rem] rounded-full bg-primary-200/30 blur-3xl" aria-hidden="true"></div>

  <div class:list={["container-page section flex flex-col gap-6", containerClass]}>
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight max-w-3xl text-secondary-900">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-secondary-600 max-w-2xl">
        {subtitle}
      </p>
    )}
    {(primaryCta || secondaryCta) && (
      <div class="mt-2 flex flex-wrap gap-3">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn-primary">
            {primaryCta.label}
            <Fragment set:html={icons.arrowRight({ class: "h-4 w-4" })} />
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-secondary">
            {secondaryCta.label}
          </a>
        )}
      </div>
    )}
  </div>
</section>
