---

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}
const { eyebrow, title, subtitle, align = "center" } = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---

<div class:list={["max-w-2xl", alignClass]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="mt-2 text-3xl md:text-4xl font-bold tracking-tight">{title}</h2>
  {subtitle && <p class="mt-3 text-lg text-secondary-600">{subtitle}</p>}
</div>
{!Astro.props.align || Astro.props.align === "center" ? (
  <div class="mt-2 mx-auto h-1 w-16 rounded-full bg-gradient-to-r from-primary-500 to-primary-700" />
) : null}
